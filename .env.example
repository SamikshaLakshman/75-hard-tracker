# MySQL Database
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:your_password@localhost:3306/hard75"

# Auth Secret (generate with: openssl rand -base64 32)
AUTH_SECRET="replace-with-random-secret-key"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend — for password reset emails (free tier, no credit card)
# Sign up at https://resend.com, get an API key from the dashboard.
# Without a verified domain, emails can only be sent to the address you signed up with.
# Leave blank to skip email sending — reset links will still print to your server console.
RESEND_API_KEY=""
